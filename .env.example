# CLIS V2 — API Keys
# Copy this file to .env and fill in your keys
# Both keys are free — no credit card needed

# Groq API key — get at console.groq.com
# Powers: LLM summaries, GRADE grading, contradiction detection, NNT extraction
GROQ_API_KEY=key

# NCBI API key — get at ncbi.nlm.nih.gov/account
# Without key: 3 PubMed requests/sec
# With key:   10 PubMed requests/sec (recommended for benchmark suite)
NCBI_API_KEY=key
